# name: test/sql/sketch2.test
# description: test sketch2 extension
# group: [sql]

# Before we load the extension, this will fail
statement error
SELECT sketch2('Sam');
----
Catalog Error: Scalar Function with name sketch2 does not exist!

# Require statement will ensure this test is run with this extension loaded
require sketch2

# Confirm the extension works
query T
SELECT sketch2('');
----
0.1.0

statement error
CALL sketch2_open('/tmp/db', 'demo');
----

query I
SELECT bitset_filter(id) > 0
FROM (SELECT 1::BIGINT AS id UNION ALL SELECT 3::BIGINT UNION ALL SELECT 9::BIGINT) t;
----
true

query I
SELECT bitset_filter(id) > 0
FROM (SELECT * FROM range(0)) t(id);
----
true

statement error
SELECT bitset_filter(-1::BIGINT);
----

statement error
CALL sketch2_open('/tmp/db');
----

statement error
CALL sketch2_open(NULL, 'demo');
----
